# --- Vercel KV (Storage tab in your Vercel project > Create Database > KV) ---
# These are added automatically when you link a KV store to this project.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Admin login (you choose this password, used at /admin) ---
ADMIN_PASSWORD=choose-a-password

# --- Twilio (for text notifications when someone requests a booking) ---
# Sign up free at twilio.com, buy a $1/mo phone number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+16262958572
